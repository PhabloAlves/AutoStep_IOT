# Copie para .env e preencha os valores antes de subir o ambiente.
# .env nunca deve ser commitado no repositório.

# JWT — gere com: python -c "import secrets; print(secrets.token_hex(32))"
AUTOSTEP_SECRET_KEY=

# MQTT
MQTT_USER=autostep
MQTT_PASSWORD=

# Usuário gestor — criado automaticamente no startup se não existir
AUTOSTEP_ADMIN_USER=admin
AUTOSTEP_ADMIN_PASSWORD=
